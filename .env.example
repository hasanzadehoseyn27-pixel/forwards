API_ID=123456
API_HASH=your_api_hash_here
BOT_TOKEN=123456:your_bot_token_here
ADMIN_IDS=123456789,987654321

# Keep this different for every bot installed on the same server.
INSTANCE_NAME=bestrobot

# Optional paths. Relative paths are resolved from the project folder.
DATA_DIR=data
LOG_DIR=logs
USER_SESSION=data/userbot.session
BOT_SESSION=data/adminbot.session

# Engine tuning
POLL_INTERVAL_SECONDS=20
REPEAT_SCAN_SECONDS=30
WORKER_COUNT=3
MAX_PARALLEL_SENDS=2
MIN_SEND_DELAY_SECONDS=1.5
MAX_JOB_ATTEMPTS=5
LOCK_STALE_SECONDS=120

# Optional Telegram proxy. Use this when Telethon times out while Telegram works through a VPN/proxy.
# Your Windows proxy screenshot looks like SOCKS5 on 127.0.0.1:10808.
PROXY_TYPE=
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=
